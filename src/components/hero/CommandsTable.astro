---
/**
 * Commands table — three rows mapping each `aic` subcommand to its purpose.
 * Lifted verbatim in shape from aic-intro.png, content from CLAUDE.md.
 */
import { COMMANDS } from '@/config/site';
---

<div class="commands" aria-label="aic commands">
  {
    COMMANDS.map((row) => (
      <div class="cmd">
        <span class="k">
          <span class="cmd-name">{row.command}</span>
          {row.args && <span class="args"> {row.args}</span>}
        </span>
        <span class="d">{row.description}</span>
      </div>
    ))
  }
</div>

<style>
  .commands {
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-line-soft);
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.012);
  }
  .cmd {
    display: grid;
    grid-template-columns: minmax(140px, max-content) 1fr;
    align-items: baseline;
    gap: 1.1rem;
    padding: 0.75rem 1.1rem;
    border-top: 1px solid var(--color-line-soft);
    font-size: 0.82rem;
  }
  .cmd:first-child {
    border-top: 0;
  }
  .k {
    color: var(--color-ink);
    font-weight: 600;
    white-space: nowrap;
    font-family: var(--font-mono);
  }
  .args {
    color: var(--color-amber);
  }
  .d {
    color: var(--color-ink-muted);
    font-size: 0.78rem;
  }
  @media (max-width: 480px) {
    .cmd {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>
