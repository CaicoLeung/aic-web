---
/**
 * Footer — final CTA + repo credit.
 */
import { GITHUB_URL, PRIMARY_INSTALL_COMMAND } from '@/config/site';
import CopyButton from '@/components/ui/CopyButton.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const compareBase = `${base}vs/aicommits/`;
---

<footer class="footer">
  <div class="footer-inner container">
    <div class="footer-cta">
      <p class="eyebrow">
        <span class="line" aria-hidden="true"></span>ship cleaner commits today
      </p>
      <h2>stop writing commit messages.</h2>
      <div class="footer-actions">
        <CopyButton
          text={PRIMARY_INSTALL_COMMAND}
          label="brew tap CaicoLeung/aic && brew install aic"
          variant="primary"
        />
        <a
          class="footer-link"
          href={GITHUB_URL}
          target="_blank"
          rel="noopener noreferrer"
        >
          ★ Star on GitHub
        </a>
      </div>
    </div>

    <div class="footer-meta">
      <a class="repo" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
        {GITHUB_URL.replace('https://', '')}
      </a>
      <nav class="footer-links" aria-label="Comparisons">
        <a href={compareBase}>aic vs aicommits</a>
      </nav>
      <p>MIT licensed · built with Astro + Tailwind + GSAP</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--color-line-soft);
    padding: clamp(3rem, 1rem + 5vw, 5rem) 0 2rem;
    background: var(--color-base-deep);
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  h2 {
    font-size: var(--text-h2);
    line-height: 1.05;
    margin: 0.75rem 0 1.5rem;
  }
  .footer-actions {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .footer-link {
    color: var(--color-ink);
    text-decoration: none;
    padding: 0.55rem 1rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    transition:
      border-color var(--duration-fast) ease,
      color var(--duration-fast) ease;
  }
  .footer-link:hover {
    border-color: var(--color-amber);
    color: var(--color-amber);
  }
  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line-soft);
    color: var(--color-ink-muted);
    font-size: 0.85rem;
  }
  .repo {
    color: var(--color-ink-muted);
    text-decoration: none;
    width: fit-content;
  }
  .repo:hover {
    color: var(--color-amber);
  }
  .footer-links {
    display: inline-flex;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .footer-links a {
    color: var(--color-ink-muted);
    text-decoration: none;
  }
  .footer-links a:hover {
    color: var(--color-amber);
  }
</style>
