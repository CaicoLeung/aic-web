---
/**
 * Auto-batching — the differentiator callout from aic-sketch.png.
 * "Nothing staged? → aic groups your unstaged work into logical commits."
 */
const roundup = `${
  import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`
}best-ai-commit-tools/`;
---

<section id="batching" class="section batching">
  <div class="batching-card container">
    <div class="batching-visual" aria-hidden="true">
      <div class="stack">
        <div class="pill">
          <span class="hash">abc1234</span> feat(auth): refresh tokens…
        </div>
        <div class="pill">
          <span class="hash">def5678</span> docs(api): endpoint reference
        </div>
        <div class="pill">
          <span class="hash">ghi9012</span> chore(deps): bump rig-core
        </div>
      </div>
    </div>
    <div class="batching-copy">
      <p class="eyebrow">
        <span class="line" aria-hidden="true"></span>03 — Auto-batching
      </p>
      <h2>nothing staged?</h2>
      <p class="lede">
        aic groups your unstaged work into logical commits — and ships each one. One <code
          >aic</code
        > command becomes a clean, reviewable history without you staging a single file.
      </p>
      <p class="aside">auto-batching ✦</p>
      <a class="cmp-link" href={roundup}>see aic among the best AI commit tools →</a>
    </div>
  </div>
</section>

<style>
  .batching {
    padding: clamp(3rem, 1rem + 6vw, 6rem) 0;
    position: relative;
    z-index: 2;
  }
  .batching-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 1rem + 3vw, 4rem);
    align-items: center;
    /* Vertical padding only — inline gutter inherits from .container
       so the card's content aligns with sibling sections. */
    padding-block: clamp(2rem, 1rem + 3vw, 3.5rem);
    border: 1px solid var(--color-line-soft);
    border-radius: 20px;
    background:
      radial-gradient(600px 320px at 20% 0%, rgba(243, 179, 64, 0.06), transparent 60%),
      rgba(21, 23, 31, 0.45);
  }
  @media (min-width: 900px) {
    .batching-card {
      grid-template-columns: 1fr 1fr;
    }
  }
  .batching-visual {
    display: grid;
    place-items: center;
    min-height: 200px;
  }
  .stack {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    max-width: 360px;
  }
  .pill {
    font-family: var(--font-mono);
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: var(--color-surface);
    font-size: 0.8rem;
    color: var(--color-ink);
    box-shadow: 0 12px 28px -18px rgba(0, 0, 0, 0.6);
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  .pill:nth-child(1) {
    transform: translateX(0);
  }
  .pill:nth-child(2) {
    transform: translateX(0.6rem);
  }
  .pill:nth-child(3) {
    transform: translateX(1.2rem);
  }
  /* Reclaim the right gutter on narrow screens — the fanned stack is a
     desktop flourish (mobile reading-experience pass). */
  @media (max-width: 480px) {
    .pill:nth-child(2),
    .pill:nth-child(3) {
      transform: none;
    }
  }
  .pill .hash {
    color: var(--color-amber);
    font-weight: 600;
    margin-right: 0.5rem;
  }
  .eyebrow {
    margin-bottom: 0.5rem;
  }
  h2 {
    font-size: var(--text-h2);
    line-height: 1.05;
    margin: 0;
  }
  .lede {
    color: var(--color-ink-muted);
    line-height: 1.65;
    margin-top: 1rem;
    font-size: var(--text-lede);
  }
  .lede code {
    color: var(--color-amber);
    background: var(--color-amber-soft);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.88em;
  }
  .aside {
    margin-top: 1rem;
    font-style: italic;
    color: var(--color-ink-muted);
    font-size: 0.9375rem;
  }
  .cmp-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-amber);
    text-decoration: none;
    font-size: 0.88rem;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) ease;
  }
  .cmp-link:hover {
    border-bottom-color: var(--color-amber);
  }
</style>
