---
/**
 * ContentHeader — lightweight header for content pages (vs/, roundup,
 * guides). The home `Topbar` is anchor-coupled (`#how`, `#batching`), so
 * article pages use this simpler, page-safe header instead.
 *
 * Brand links home via BASE_URL (base-path safe). Reuses the Topbar mark.
 */
import { GITHUB_URL } from '@/config/site';

interface Props {
  readonly version?: string;
}
const { version } = Astro.props;
const home = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<header class="content-header">
  <a class="brand" href={home} aria-label="aic — home">
    <span class="mark" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="20" height="20" focusable="false">
        <path d="M10,5 Q10,13 18,13 Q10,13 10,21 Q10,13 2,13 Q10,13 10,5 Z" fill="#1a1408"></path>
        <path d="M18,2 Q18,6 22,6 Q18,6 18,10 Q18,6 14,6 Q18,6 18,2 Z" fill="#1a1408"></path>
      </svg>
    </span>
    <span class="brand-name">aic</span>
  </a>

  <nav class="content-nav" aria-label="Site">
    {version && <span class="version">v{version}</span>}
    <a href={home}>home</a>
    <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
      GitHub<span aria-hidden="true"> ↗</span>
    </a>
  </nav>
</header>

<style>
  .content-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.9rem clamp(1.25rem, 0.4rem + 2vw, 3rem);
    background: color-mix(in oklch, var(--color-base-deep) 78%, transparent);
    border-bottom: 1px solid var(--color-line-soft);
    backdrop-filter: blur(14px) saturate(140%);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
  }
  .mark {
    width: 32px;
    height: 32px;
    border-radius: 9px;
    background: linear-gradient(145deg, var(--color-amber), var(--color-amber-warm));
    display: grid;
    place-items: center;
    box-shadow:
      0 8px 22px -8px rgba(243, 179, 64, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: -0.01em;
  }
  .content-nav {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .content-nav a {
    text-decoration: none;
    color: var(--color-ink-muted);
    transition: color var(--duration-fast) ease;
  }
  .content-nav a:hover {
    color: var(--color-amber);
  }
  .version {
    color: var(--color-ink-dim);
    font-variant-numeric: tabular-nums;
  }
  @media (max-width: 480px) {
    .version {
      display: none;
    }
  }
</style>
