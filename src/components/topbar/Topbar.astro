---
/**
 * Sticky topbar — brand left, anchor nav center, version + GitHub right.
 * Background blur kicks in after the hero scrolls past (Tier 2 motion).
 */
import { GITHUB_URL } from '@/config/site';

interface Props {
  readonly version: string;
}
const { version } = Astro.props;
---

<header class="topbar" data-topbar>
  <a class="brand" href="#top" aria-label="aic — home">
    <span class="mark" aria-hidden="true">
      <svg class="mark-svg" viewBox="0 0 24 24" width="22" height="22" focusable="false">
        <path d="M10,5 Q10,13 18,13 Q10,13 10,21 Q10,13 2,13 Q10,13 10,5 Z" fill="#1a1408" />
        <path d="M18,2 Q18,6 22,6 Q18,6 18,10 Q18,6 14,6 Q18,6 18,2 Z" fill="#1a1408" />
      </svg>
    </span>
    <span class="brand-text">
      <span class="brand-name">aic</span>
      <span class="brand-tag">AI-powered git commits</span>
    </span>
  </a>

  <nav class="nav" aria-label="Sections">
    <a href="#how">how</a>
    <a href="#batching">batching</a>
    <a href="#providers">providers</a>
    <a href="#install">install</a>
  </nav>

  <div class="meta">
    <span class="version" title={`Latest release: v${version}`}>
      <span class="version-dot" aria-hidden="true"></span>
      v{version}
    </span>
    <a class="github" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
      GitHub
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1rem clamp(1rem, 0.4rem + 2vw, 3rem);
    background: color-mix(in oklch, var(--color-base-deep) 70%, transparent);
    border-bottom: 1px solid transparent;
    backdrop-filter: blur(0);
    transition:
      border-color var(--duration-normal) var(--ease-out-expo),
      backdrop-filter var(--duration-normal) var(--ease-out-expo),
      background var(--duration-normal) var(--ease-out-expo);
  }
  .topbar[data-blur='true'] {
    border-bottom-color: var(--color-line-soft);
    backdrop-filter: blur(14px) saturate(140%);
    background: color-mix(in oklch, var(--color-base-deep) 80%, transparent);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    color: inherit;
  }
  .mark {
    width: 38px;
    height: 38px;
    border-radius: 11px;
    background: linear-gradient(145deg, var(--color-amber), var(--color-amber-warm));
    display: grid;
    place-items: center;
    box-shadow:
      0 10px 28px -8px rgba(243, 179, 64, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .mark-svg {
    display: block;
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  .brand:hover .mark-svg {
    transform: rotate(12deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .mark-svg,
    .brand:hover .mark-svg {
      transition: none;
      transform: none;
    }
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.06rem;
    letter-spacing: -0.01em;
  }
  .brand-tag {
    font-size: 0.72rem;
    color: var(--color-ink-muted);
  }
  .nav {
    display: none;
    gap: 1.75rem;
    font-size: 0.82rem;
    color: var(--color-ink-muted);
  }
  .nav a {
    text-decoration: none;
    color: inherit;
    transition: color var(--duration-fast) ease;
  }
  .nav a:hover {
    color: var(--color-amber);
  }
  .meta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.78rem;
  }
  .version {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
  }
  .version-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-mint);
    box-shadow: 0 0 0 3px var(--color-mint-soft);
  }
  .github {
    text-decoration: none;
    color: var(--color-ink);
    font-weight: 600;
    transition: color var(--duration-fast) ease;
  }
  .github:hover {
    color: var(--color-amber);
  }
  @media (min-width: 768px) {
    .nav {
      display: inline-flex;
    }
  }
</style>

<script>
  // Toggle blur after the hero scrolls past — cheap, scroll-driven.
  const topbar = document.querySelector('[data-topbar]');
  if (topbar) {
    const onScroll = () => {
      topbar.setAttribute('data-blur', String(window.scrollY > 80));
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
