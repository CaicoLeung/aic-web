---
/**
 * Base layout — HTML shell, head, font preloads, OG metadata.
 * Spiritual-adaptation (ADR-0002): palette + grain + glows come from
 * the design tokens in global.css, not hardcoded here.
 */
import '@/styles/global.css';

interface Props {
  readonly version: string;
  readonly title?: string;
  readonly description?: string;
  /** Per-page structured data. Omit on the home page to keep the default
   *  SoftwareApplication schema. Pass an Article-shaped object on content
   *  pages so a comparison page isn't mistagged as the app itself. */
  readonly schema?: Record<string, unknown> | readonly Record<string, unknown>[];
}

const {
  version,
  title = 'aic — AI-powered git commits',
  description = 'aic reads your diff, drafts a conventional commit, and commits it — one command. Nothing staged? It groups your work into logical commits for you.',
  schema,
} = Astro.props;

// Home keeps SoftwareApplication; content pages pass their own schema.
const jsonLd =
  schema ??
  ({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'aic',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'macOS, Linux, Windows',
    softwareVersion: `v${version}`,
    description,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  });

const site = Astro.site?.toString() ?? 'https://caicoleung.github.io';
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL('/aic-web/og.png', site).toString();
const themeColor = '#0e0f14';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <meta
      name="google-site-verification"
      content="Ih8LNd1hTZy3EI4Hx-_wx21ruZj5gR6eosSk1l47b5A"
    />
    <link rel="canonical" href={canonical} />

    <!-- icons -->
    <link rel="icon" href="/aic-web/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/aic-web/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/aic-web/manifest.webmanifest" />

    <!-- apple web app -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="aic" />

    <!-- fonts — preload only regular weight (Q12 hybrid) -->
    <link
      rel="preload"
      href="/aic-web/fonts/JetBrainsMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- open graph / twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- structured data — SoftwareApplication (home) or per-page schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <!-- PWA: register service worker (progressive enhancement — fails silently) -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/aic-web/sw.js').catch(() => {});
        });
      }
    </script>

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="relative z-2 contents">
      <slot />
    </div>
  </body>
</html>
