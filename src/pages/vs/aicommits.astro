---
/**
 * /vs/aicommits — head-to-head comparison page (ADR-0006).
 *
 * Fair by design (CONTEXT.md → "vs page"): concedes where aicommits wins,
 * wins decisively on aic's differentiators. Comparison facts are editorial
 * judgments from src/config/competitors.ts, verified against both READMEs.
 *
 * Targets the "aicommits alternative" / migration cluster. Article schema
 * (not SoftwareApplication) since this is content, not the app listing.
 */
import { loadAicFacts } from '@/data/aic';
import Base from '@/layouts/Base.astro';
import ContentHeader from '@/components/content/ContentHeader.astro';
import Footer from '@/components/footer/Footer.astro';
import CopyButton from '@/components/ui/CopyButton.astro';
import { AICOMMITS_COMPARISON } from '@/config/competitors';
import { GITHUB_URL, PRIMARY_INSTALL_COMMAND } from '@/config/site';

const facts = await loadAicFacts();
const { rival, axes } = AICOMMITS_COMPARISON;
const aicWins = axes.filter((a) => a.winner === 'aic');
const rivalWins = axes.filter((a) => a.winner === 'rival');
const ties = axes.filter((a) => a.winner === 'tie');

const title = `aic vs aicommits — AI commit tool comparison`;
const description = `aicommits is the established default. aic is the pick if you want auto-batching, first-class Anthropic/Gemini/DeepSeek, and no Node.js dependency. An honest, feature-by-feature comparison.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: '2026-07-08',
  dateModified: '2026-07-09',
  author: { '@type': 'Organization', name: 'aic' },
  publisher: { '@type': 'Organization', name: 'aic' },
  about: ['aic', 'aicommits', 'AI commit message tools'],
};
---

<Base version={facts.version} title={title} description={description} schema={schema}>
  <ContentHeader version={facts.version} />

  <main id="main">
    <article class="container article">
      <p class="eyebrow"><span class="line" aria-hidden="true"></span>Comparison · aicommits alternative</p>
      <h1>aic vs aicommits</h1>
      <p class="lede">
        <a href={rival.repo} target="_blank" rel="noopener noreferrer">aicommits</a>
        is the entrenched default for AI-written commit messages — the install base, the
        ecosystem, the first-mover momentum. This page isn’t here to pretend otherwise.
        It’s here to tell you exactly when <strong>aic</strong> is the better pick — and when
        you should just stay on aicommits.
      </p>

      <aside class="callout">
        <strong>Small world.</strong> aicommits’ own README suggests aliasing it to
        <code>aic</code> if the name is too long. We shipped <code>aic</code> as its own
        thing — and it auto-batches your unstaged work into separate commits.
      </aside>

      <!-- Feature matrix -->
      <section class="block">
        <h2>Feature-by-feature</h2>
        <div class="table-wrap">
          <table class="matrix">
            <thead>
              <tr>
                <th scope="col">Capability</th>
                <th scope="col">aic</th>
                <th scope="col">{rival.name}</th>
              </tr>
            </thead>
            <tbody>
              {axes.map((axis) => (
                <tr>
                  <th scope="row">{axis.feature}</th>
                  <td class={axis.winner === 'aic' ? 'win' : ''}>
                    {axis.aic.supported === true && <span class="glyph yes" aria-hidden="true">✓</span>}
                    {axis.aic.supported === false && <span class="glyph no" aria-hidden="true">✗</span>}
                    <span>{axis.aic.text}</span>
                  </td>
                  <td class={axis.winner === 'rival' ? 'win' : ''}>
                    {axis.rival.supported === true && <span class="glyph yes" aria-hidden="true">✓</span>}
                    {axis.rival.supported === false && <span class="glyph no" aria-hidden="true">✗</span>}
                    <span>{axis.rival.text}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Where aic wins -->
      <section class="block">
        <h2>Where aic pulls ahead</h2>
        <ul class="points">
          {aicWins.map((axis) => (
            <li>
              <span class="point-h">{axis.feature}</span>
              <span class="point-n">{axis.note}</span>
            </li>
          ))}
          {ties.map((axis) => (
            <li>
              <span class="point-h">{axis.feature} <span class="tie-tag">trade-off</span></span>
              <span class="point-n">{axis.note}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Where aicommits wins (the fair concession) -->
      <section class="block">
        <h2>Where aicommits still wins</h2>
        <p class="block-lede">
          We’re not going to pretend aic beats the popular tool on everything. It doesn’t.
          If any of these matter more to you than auto-batching, aicommits is the right call:
        </p>
        <ul class="points">
          {rivalWins.map((axis) => (
            <li>
              <span class="point-h">{axis.feature}</span>
              <span class="point-n">{axis.note}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Verdict + CTA -->
      <section class="verdict">
        <h2>The short version</h2>
        <p>
          If your unstaged work piles up and you want it split into clean, logical commits —
          or you want Claude, Gemini, or DeepSeek as first-class providers without a Node.js
          dependency — switch to <strong>aic</strong>. If you want a <code>git commit</code>
          hook, gitmoji commits, multiple candidates to pick from, or just the comfort of the
          popular choice, aicommits is still a great tool.
        </p>
        <div class="cta">
          <CopyButton
            text={PRIMARY_INSTALL_COMMAND}
            label="brew tap CaicoLeung/aic && brew install aic"
            variant="primary"
          />
          <a class="cta-link" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
            ★ Star on GitHub
          </a>
        </div>
      </section>
    </article>
  </main>

  <Footer />
</Base>

<style>
  .article {
    max-width: 820px;
    padding-block: clamp(2.5rem, 1rem + 4vw, 4.5rem) clamp(3rem, 1rem + 5vw, 5rem);
    position: relative;
    z-index: 2;
  }
  h1 {
    font-size: var(--text-h2);
    line-height: 1.05;
    margin: 0.75rem 0 0;
  }
  .lede {
    color: var(--color-ink-muted);
    line-height: 1.65;
    margin-top: 1rem;
    font-size: var(--text-lede);
  }
  .lede a {
    color: var(--color-amber);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklch, var(--color-amber) 40%, transparent);
  }

  .callout {
    margin-top: 1.75rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-amber);
    border-radius: 10px;
    background: var(--color-amber-soft);
    color: var(--color-ink);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .callout code {
    color: var(--color-amber);
    font-family: var(--font-mono);
  }

  .block {
    margin-top: 2.75rem;
  }
  .block h2 {
    font-size: 1.5rem;
    margin: 0 0 1rem;
  }
  .block-lede {
    color: var(--color-ink-muted);
    margin: -0.25rem 0 1.25rem;
    line-height: 1.6;
    font-size: 0.975rem;
  }

  /* Matrix table */
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-line-soft);
    border-radius: 12px;
  }
  .matrix {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    min-width: 520px;
  }
  .matrix th,
  .matrix td {
    text-align: left;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-line-soft);
    vertical-align: top;
  }
  .matrix thead th {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    background: var(--color-surface);
  }
  .matrix tbody th {
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-ink);
    max-width: 16rem;
  }
  .matrix tbody tr:last-child th,
  .matrix tbody tr:last-child td {
    border-bottom: none;
  }
  .matrix td {
    color: var(--color-ink-muted);
  }
  .matrix td.win {
    color: var(--color-ink);
    background: var(--color-amber-soft);
  }
  .glyph {
    font-weight: 700;
    margin-right: 0.4rem;
  }
  .glyph.yes {
    color: var(--color-mint);
  }
  .glyph.no {
    color: var(--color-ink-dim);
  }

  /* Point lists */
  .points {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .points li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .point-h {
    font-weight: 600;
    color: var(--color-ink);
  }
  .point-n {
    color: var(--color-ink-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .tie-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.05rem 0.45rem;
    margin-left: 0.4rem;
    vertical-align: middle;
  }

  /* Verdict */
  .verdict {
    margin-top: 2.75rem;
    padding: 1.75rem;
    border: 1px solid var(--color-line-soft);
    border-radius: 14px;
    background: var(--color-surface);
  }
  .verdict h2 {
    font-size: 1.5rem;
    margin: 0 0 0.75rem;
  }
  .verdict p {
    color: var(--color-ink-muted);
    line-height: 1.65;
  }
  .verdict code {
    color: var(--color-amber);
    font-family: var(--font-mono);
  }
  .cta {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .cta-link {
    color: var(--color-ink);
    text-decoration: none;
    padding: 0.55rem 1rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    transition:
      border-color var(--duration-fast) ease,
      color var(--duration-fast) ease;
  }
  .cta-link:hover {
    border-color: var(--color-amber);
    color: var(--color-amber);
  }
</style>
